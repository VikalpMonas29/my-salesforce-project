<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId" controller="ReviewController">
    <aura:attribute name="reviewList" type="List" />

    <lightning:button label="Get All Reviews" onclick="{!c.getReviews}" />

    <table border="1" cellpadding="8" cellspacing="0" align="center" style="border-collapse: collapse; width: 80%; margin: 20px auto;">
        <thead>
            <tr style="background-color: lightgrey;">
                <th style="padding: 10px;">Name</th>
                <th style="padding: 10px;">Core Competencies</th>
                <th style="padding: 10px;">Candidate Name</th>
                <th style="padding: 10px;">Experience</th>
                <th style="padding: 10px;">Leadership Skills</th>
                <th style="padding: 10px;">Recommend for Hire</th>
                <th style="padding: 10px;">Overall Review Score</th>
            </tr>
        </thead>
        <tbody>
            <aura:iteration items="{!v.reviewList}" var="review">
                <tr>
                    <td style="padding: 10px;">{!review.Name}</td>
                    <td style="padding: 10px;">{!review.Core_Competencies__c}</td>
                    <td style="padding: 10px;">{!review.Candidate_Name__c}</td>
                    <td style="padding: 10px;">{!review.Experience__c}</td>
                    <td style="padding: 10px;">{!review.Leadership_Skills__c}</td>
                    <td style="padding: 10px;">{!review.Recommend_for_Hire__c}</td>
                    <td style="padding: 10px;">{!review.Overall_Review_Score__c}</td>
                </tr>
            </aura:iteration>
        </tbody>
    </table>
</aura:component>